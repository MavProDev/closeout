# Supabase Postgres, transaction pooler URL (used at runtime by Prisma Client)
DATABASE_URL=

# Supabase Postgres, direct connection (used by `prisma migrate` only)
DIRECT_URL=

# Public Supabase project URL and anon key (safe to expose to the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key, server-only. Used by Server Actions to write past RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Storage bucket name for punch photos (defaults to "punch-photos" in code)
SUPABASE_STORAGE_BUCKET=punch-photos
