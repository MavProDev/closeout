# These env names match what the Vercel-Supabase Marketplace integration
# auto-injects into a linked Vercel project. Pull locally with:
#
#   vercel env pull .env.local
#
# Never copy/paste these by hand. The Marketplace integration is the
# source of truth — when Supabase rotates the database password,
# Vercel auto-syncs, the next deploy picks it up.

# Postgres, transaction pooler with pgbouncer=true (Prisma Client at runtime)
POSTGRES_PRISMA_URL=

# Postgres, direct connection (used by `prisma migrate` only)
POSTGRES_URL_NON_POOLING=

# Public Supabase project URL and anon key (browser-safe).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key, server-only. Used by Server Actions to mint signed
# Storage upload URLs and by any write that needs to bypass RLS in V1.
SUPABASE_SERVICE_ROLE_KEY=

# Optional override of the Storage bucket name (defaults to "punch-photos").
SUPABASE_STORAGE_BUCKET=punch-photos
