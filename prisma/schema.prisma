// Closeout punch list tracker.
//
// The original take-home schema is preserved exactly. Field names
// are not renamed. Five fields and three indexes were added to extend
// the model from CRUD to a workflow tool:
//
//   updatedAt        - audit trail (workflow tools require it)
//   completionPhoto  - separate from `photo`. The original documents
//                      the defect; the completion photo documents the
//                      fix. Industry best practice (EB3, Smartsheet).
//   completedAt      - closeout velocity reporting
//   verifiedAt       - GC sign-off timestamp
//   deletedAt        - soft-delete only. Construction audit trails
//                      matter. Items are never hard-deleted.
//
// Indexes on (projectId, status), (projectId, priority), and
// (projectId, deletedAt) make every dashboard breakdown query cheap.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Vercel-Supabase Marketplace integration injects these env names.
  // POSTGRES_PRISMA_URL is the transaction pooler with pgbouncer=true
  // (correct runtime URL for Prisma Client).
  // POSTGRES_URL_NON_POOLING is the direct connection used for
  // migrations only (pooler doesn't support DDL).
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL")
  directUrl = env("POSTGRES_URL_NON_POOLING")
}

model Project {
  id        String      @id @default(uuid())
  name      String
  address   String
  /// Decorative. Never written to by application code. Project status
  /// is computed at render time from item counts (see
  /// `computeProjectStatus` in lib/state.ts). A CHECK constraint
  /// pinning this to 'active' is added in migration
  /// 20260501170000_rls_and_storage_policies so any accidental write
  /// fails loudly instead of silently producing a wrong dashboard.
  status    String      @default("active")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  items     PunchItem[]

  @@index([status])
}

model PunchItem {
  id              String    @id @default(uuid())
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectId       String
  location        String
  description     String
  status          String    @default("open")
  priority        String    @default("normal")
  assignedTo      String?
  photo           String?
  completionPhoto String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  completedAt     DateTime?
  verifiedAt      DateTime?
  deletedAt       DateTime?

  @@index([projectId, status])
  @@index([projectId, priority])
  @@index([projectId, deletedAt])
}
